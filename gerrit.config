[plugin "ai-code-review"]
	aiToken = <CHATGPT_API_TOKEN>
	aiModel = gpt-4
	aiStreamOutput = false
	gerritUserName = <GERRIT_USER_NAME>
	globalEnable = true

# Example configuration for Anthropic (Claude). Uncomment and replace the token above
# to route reviews through Anthropic's Messages API instead of OpenAI.
